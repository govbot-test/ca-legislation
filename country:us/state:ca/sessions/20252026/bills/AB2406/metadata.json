  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law authorizes a political subdivision to lease, or to acquire and lease or sublease, a lot or building to a veterans association, veterans service organization, or nonprofit veterans service agency for up to 20 years, as specified.\n\nThis bill would make technical, nonsubstantive changes to this provision."
    }
  ],
