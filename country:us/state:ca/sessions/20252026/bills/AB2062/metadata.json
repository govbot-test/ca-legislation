{
  "legislative_session": "20252026",
  "identifier": "AB2062",
  "title": "Security surveillance companies: access and use of content.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Securitysurveillancecompanies",
    "accessanduseofcontent"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes various privacy protections relating to the collection, use, sale, or distribution of personal information, images, or video recordings, including restrictions relating to the retention, access, use, sale, or sharing of images or video recordings collected through the operation of an in-vehicle camera.\n\nThis bill would prohibit a security surveillance company, as defined, from distributing, selling, or otherwise authorizing a third party to access, use, or distribute content obtained from a consumer's security surveillance system without first obtaining the express consent of the consumer and the adult residents of a residential rental property or upon receipt of an order of a court or arbitrator."
    }
  ],
