  "identifier": "AB1446",
  "title": "Community colleges: job market study.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Communitycolleges",
    "jobmarketstudy"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the California Community Colleges, under the administration of the Board of Governors of the California Community Colleges, as one of the segments of public postsecondary education in this state. Existing law establishes community college districts throughout the state, and authorizes them to provide instruction at the campuses they operate and maintain. Existing law requires the governing board of a community college district, before establishing a vocational or occupational training program, to conduct a job market study of the labor market area, as specified. \n\nThis bill would make nonsubstantive changes in the latter provision."
    }
  ],
