{
  "legislative_session": "20252026",
  "identifier": "AB1905",
  "title": "Juveniles: custodial interrogation.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Juveniles",
    "custodialinterrogation"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law prohibits law enforcement officers from employing threats, physical harm, deception, or psychologically manipulative interrogation tactics, as specified, during a custodial interrogation of a person 17 years of age or younger.\n\nThis bill would prohibit a law enforcement officer from seeking statements or information while working undercover, or by individuals working in collaboration with, or acting as agents of, law enforcement, from a person who was 17 years of age or younger during the commission of crime and who is under 26 years of age while in custody. The bill would direct a court to consider any willful failure of a law enforcement officer in violation of these provisions in determining the credibility of that law enforcement officer."
    }
  ],
