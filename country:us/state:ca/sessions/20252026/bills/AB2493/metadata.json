  "legislative_session": "20252026",
  "identifier": "AB2493",
  "title": "Electrical corporations: interconnection: transmission: permitting: auditor.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Electricalcorporations",
    "auditor",
