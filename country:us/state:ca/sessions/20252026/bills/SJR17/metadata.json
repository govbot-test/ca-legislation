  "subject": [
    "KoreanAmericanveterans"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would urge the Congress and President of the United States to permit states to extend burial and memorial benefits in state cemeteries to Republic of Korea veterans who served in the Vietnam War and who subsequently became United States citizens."
    }
  ],
