{
  "legislative_session": "20252026",
  "identifier": "SB1410",
  "title": "Adult community care facilities: email address of record.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Adultcommunitycarefacilities",
    "emailaddressofrecord"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law, the California Community Care Facilities Act, provides for the licensure and regulation of community care facilities by the State Department of Social Services, including various adult residential facilities. Existing law requires an applicant or licensee of an adult community care facility or residential care facility, as specified, to maintain an email address of record with the department, and to provide written notification to the department of the email address and of any change to the email address within 10 business days of the change.\n\nThis bill would instead require the applicant or licensee to provide the written notification of any change to the email address of record within 12 business days."
    }
  ],
