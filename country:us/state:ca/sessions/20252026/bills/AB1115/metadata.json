  "legislative_session": "20252026",
  "identifier": "AB1115",
  "title": "Peace officers: mental health liaisons.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Peaceofficers",
    "mentalhealthliaisons"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The California Constitution authorizes local governments to make and enforce all police and sanitary ordinances and regulations within its limits that are not in conflict with general laws. Existing law requires the board of supervisors of a county and the governing body of a city to take measures necessary to preserve and protect the public health in its jurisdiction.\n\nThis bill would authorize a local government to designate one or more existing employees specializing in counseling or mental health services as a law enforcement mental health liaison to facilitate mental health support for peace officers who serve the local jurisdiction.\n\nThe bill would make related findings and declarations."
    }
  ],
