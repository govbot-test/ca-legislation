{
  "legislative_session": "20252026",
  "identifier": "AB1093",
  "title": "Public postsecondary education: academic exchange programs: plan.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Publicpostsecondaryeducation",
    "academicexchangeprograms",
    "plan"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the California State University, under the administration of the Trustees of the California State University, and the University of California, under the administration of the Regents of the University of California, as 2 of the 3 segments of public postsecondary education in the state.\n\nThis bill, commencing with the 2027\u201328 academic year, would require the California State University, and would request the University of California, to adopt a plan to increase the number of students participating in exchange programs with Mexican public universities, as provided. The bill would require these provisions to become operative only upon an appropriation of funds for its purposes."
    }
  ],
