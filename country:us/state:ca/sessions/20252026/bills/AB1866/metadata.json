{
  "legislative_session": "20252026",
  "identifier": "AB1866",
  "title": "California Disaster Assistance Act: minimum damages thresholds.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CaliforniaDisasterAssistanceAct",
    "minimumdamagesthresholds"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law, the California Disaster Assistance Act, requires the Director of Emergency Services to provide financial assistance to local agencies for their personnel costs, equipment costs, and the cost of supplies and materials used during disaster response activities, incurred as a result of a state of emergency proclaimed by the Governor, subject to specified criteria. \n\nThis bill would require the director, in administering those provisions, to prioritize local agencies that are not eligible for federal funding due to the agency's inability to meet minimum damage thresholds under federal law, as specified.\n\nThe California Disaster Assistance Act limits the state share for any eligible project to no more than 75% of total state eligible costs unless the local agency is located within a city, county, or city and county that has adopted a local hazard mitigation plan in accordance with specified federal law.\n\nThis bill would specify costs that may be included in the local agency cost share."
    }
  ],
