  ],
  "subject": [
    "Certificatesofpublicconvenienceandnecessity"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law prohibits gas corporations, electrical corporations, telegraph corporations, telephone corporations, water corporations, sewer system corporations, and certain railroad corporations from beginning construction of a street railroad, line, plant, or system without having first obtained from the Public Utilities Commission a certificate that the present or future public convenience and necessity requires or will require the construction, as specified.\n\nThis bill would make a nonsubstantive change to that provision."
    }
  ],
