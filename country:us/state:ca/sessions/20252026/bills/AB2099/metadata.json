  "legislative_session": "20252026",
  "identifier": "AB2099",
  "title": "Advertising displays: customary maintenance.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Advertisingdisplays",
    "customarymaintenance"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The Outdoor Advertising Act regulates placement of advertising displays adjacent to and within specified distances of highways that are part of the national system of interstate and defense highways and federal-aid highways. The act prohibits limitations on the customary maintenance of a lawfully erected advertising display within the state by any governmental entity without payment of compensation, as specified.\n\nThis bill would authorize, as part of customary maintenance, an activity performed for the purpose of maintaining an advertising display in its existing physical configuration, including, but not limited to, replacing structural members and using stronger materials, as specified."
    }
  ],
