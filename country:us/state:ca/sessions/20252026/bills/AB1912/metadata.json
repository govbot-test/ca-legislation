  "legislative_session": "20252026",
  "identifier": "AB1912",
  "title": "Deer: archery season: concealed firearms.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Deer",
    "archeryseason",
    "concealedfirearms"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes an archery season for the taking of deer with bow and arrow. Existing law generally prohibits a person taking or attempting to take deer during that archery season from carrying, or having under their immediate control, a firearm of any kind, except for an active or honorably retired peace officer, as specified.\n\nThis bill would repeal that prohibition."
    }
  ],
