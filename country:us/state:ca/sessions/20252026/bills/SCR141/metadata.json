{
  "legislative_session": "20252026",
  "identifier": "SCR141",
  "title": "Relative to Women's Equal Pay Day.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "Women'sEqualPayDay"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would recognize March 26, 2026, as Women's Equal Pay Day in California, in recognition of the need to eliminate the gender gap in earnings by women and to promote policies to ensure equal pay for all."
    }
  ],
