{
  "legislative_session": "20252026",
  "identifier": "AB488",
  "title": "Insurance: the California FAIR Plan Association.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Insurance",
    "theCaliforniaFAIRPlanAssociation"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law required, within 90 days after July 23, 2021, the California FAIR Plan Association to file a new or amended rate application for basic property insurance with the Insurance Commissioner. Existing law also requires the association to establish and maintain a statewide toll-free telephone number through which a person may receive information and assistance in applying for insurance through the plan and to cause the toll-free telephone number to be published in all general distribution telephone directories in the state. \n\nThis bill would repeal the requirement to file a new or amended rate application and would delete the requirement that the toll-free number be published in all general distribution telephone directories in the state."
    }
  ],
