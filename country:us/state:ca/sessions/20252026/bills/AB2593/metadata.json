{
  "legislative_session": "20252026",
  "identifier": "AB2593",
  "title": "Corrections: treatment of prisoners.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Corrections",
    "treatmentofprisoners"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law prohibits the Department of Corrections Rehabilitation from allowing any lack of care that would injure or impair the health of an incarcerated person. Existing law prohibits the department from modifying or canceling the medical treatment of an incarcerated person if a physician certifies that the medical treatment is required to prevent certain violations of law or to prevent serious and imminent harm to the health of an incarcerated person, as specified.\n\nThis bill would prohibit a supervisor, administrator, or employee of the department from interfering with or refusing to implement prescribed health care, as specified, that results in substantial emotional distress or serious bodily injury, as defined."
    }
  ],
