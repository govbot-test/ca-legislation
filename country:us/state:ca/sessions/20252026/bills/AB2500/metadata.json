  "legislative_session": "20252026",
  "identifier": "AB2500",
  "title": "Immigration services: immigration bonds.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Immigrationservices",
    "immigrationbonds"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the State Department of Social Services, subject to an appropriation, to provide grants to qualified nonprofit organizations through contracts, in order to provide persons with certain immigration-related legal services, including, among other things, services to obtain other immigration remedies and benefits. Existing law defines immigration benefits as including advanced parole, employment authorization documents, and lawful Permanent Resident Card renewal.\n\nThis bill would expand the meaning of immigration benefits for these purposes to also include assistance with immigration bonds."
    }
  ],
