{
  "legislative_session": "20252026",
  "identifier": "SB546",
  "title": "Collection Licensing Act: exceptions: billing agents.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CollectionLicensingAct",
    "billingagents",
    "exceptions"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The Debt Collection Licensing Act generally regulates the business of debt collection and prohibits a person from engaging in the business of debt collection in this state without first obtaining a license pursuant to the act. The act provides that it does not apply to certain institutions and persons.\n\nThis bill would provide that the act does not apply to billing agents, except as specified."
    }
  ],
