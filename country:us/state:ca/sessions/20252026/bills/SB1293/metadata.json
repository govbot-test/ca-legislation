  "legislative_session": "20252026",
  "identifier": "SB1293",
  "title": "State highways: projects: notice.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Statehighways",
    "notice",
    "projects"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Department of Transportation and requires it to improve and maintain the state highways, as provided.\n\nThis bill would require the department to provide written notice of certain construction or maintenance projects within the right-of-way of a state highway in a county with a population of 60,000 people or fewer to a person who resides in, or a business that is located within, 5 miles of the project limits, as specified. The bill would also require the department to place the notice on its internet website."
    }
  ],
