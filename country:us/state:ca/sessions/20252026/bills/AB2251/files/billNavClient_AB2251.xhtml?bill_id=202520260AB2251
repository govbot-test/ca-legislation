d><td style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><div style="font-size:10pt; text-align:right; text-indent:0pt;">$59,000 </div></td><td style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><div style="font-size:10pt; text-align:right; text-indent:0pt;">$30,300 </div></td></tr><tr style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><td style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><div style="font-size:10pt; text-align:left; ; text-indent:0pt;">Two</div></td><td style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><div style="font-size:10pt; text-align:right; text-indent:0pt;">$57,600 </div></td><td style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><div style="font-size:10pt; text-align:right; text-indent:0pt;">$26,900 </div></td></tr><tr style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><td style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><div style="font-size:10pt; text-align:left; ; text-indent:0pt;"><br/> Independent</div></td><td style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><div style="font-size:10pt; text-align:right; text-indent:0pt;"><br/> </div></td><td style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><div style="font-size:10pt; text-align:right; text-indent:0pt;"> </div></td></tr><tr style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><td style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><div style="font-size:10pt; text-align:left; ; text-indent:0pt;">Single, no dependents</div></td><td style="vertical-align:middle;border-collapse: collapse;border: #ccc 1px solid; "><div style="font-size:10pt; text-align:right; text-indent:0pt;">$23,500 </div></td><td style="vertical-align:middle;bord