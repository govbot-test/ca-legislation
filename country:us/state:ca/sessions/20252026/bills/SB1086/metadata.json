  ],
  "subject": [
    "Microschoolsandmicro-educationentities"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law authorizes the legislative body of any county or city to adopt ordinances that, among other things, regulate the use of buildings, structures, and land as between industry, business, residences, open space, and other purposes.\n\nThis bill would require the Office of Land Use and Climate Innovation, in consultation with specified state entities, to develop and publish one or more model ordinances regarding micro-education entities and microschools. The bill would define various terms for these purposes."
    }
  ],
  "other_titles": [
