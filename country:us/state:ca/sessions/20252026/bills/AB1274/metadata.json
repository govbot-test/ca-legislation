  "identifier": "AB1274",
  "title": "Recycling: beverage containers.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Recycling",
    "beveragecontainers"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the California Beverage Container Recycling and Litter Reduction Act, which requires that every beverage container sold or offered for sale in this state have a refund value. The act requires a beverage distributor to pay a redemption payment to the Department of Resources Recycling and Recovery for every beverage container sold or offered for sale in the state to a dealer, and requires the department to deposit those amounts in the California Beverage Container Recycling Fund.\n\nThis bill would state the intent of the Legislature to enact subsequent legislation to implement policies to encourage the use of in-state collected plastic beverage container materials for reuse in manufacturing and packaging in state."
    }
  ],
