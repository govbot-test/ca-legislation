  "subject": [
    "Imprisonment"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires a felony sentence punishable pursuant to specified provisions to be served in the county jail. Existing law requires these sentences to be served in the state prison if, among other things, the defendant has a current or prior serious or violent felony conviction or the defendant is required to register as a sex offender.\n\nThis bill would additionally require the sentence to be served in the state prison if the sentence results in a total term of imprisonment exceeding 6 years."
    }
  ],
