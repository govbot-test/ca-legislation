  "legislative_session": "20252026",
  "identifier": "SCR163",
  "title": "Relative to California Tourism Month.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "CaliforniaTourismMonth"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would proclaim the month of May 2026 as California Tourism Month and would urge the citizens of this great state to support tourism and local businesses by traveling in the state as an act of civic pride."
    }
  ],
