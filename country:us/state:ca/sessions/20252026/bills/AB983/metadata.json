{
  "legislative_session": "20252026",
  "identifier": "AB983",
  "title": "Vehicles: removal and impoundment.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Vehicles",
    "removalandimpoundment"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires a magistrate to issue a warrant or order authorizing a peace officer to immediately seize and cause the removal of a vehicle if the magistrate is presented with a peace officer's affidavit establishing reasonable cause to believe that the vehicle was an instrumentality used in the peace officer's presence in violation of specified offenses, including, among others, a person who engages in a motor vehicle speed contest or exhibition of speed on a highway or in an offstreet parking facility, as specified.\n\nExisting law makes it a crime to drive a vehicle upon a highway at a speed greater than 100 miles per hour.\n\nThis bill would include the above-described crime in the list of offenses for which a peace officer may impound a vehicle pursuant to a warrant or order issued by a magistrate."
    }
  ],
