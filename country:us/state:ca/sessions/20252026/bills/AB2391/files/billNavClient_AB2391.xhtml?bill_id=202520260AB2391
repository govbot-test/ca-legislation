            <script>
            function getTableColumnCount(table) {
                var columnCount = 0;
                var rows = table.rows;
                if (rows !== null) {
                    if (rows.length > 0) {
                        var cells = rows[0].cells;
                        for (var i = 0, len = cells.length; i < len; ++i) {
                                // alert("i=" + i + "colspan=" + cells[i].colSpan);
                                columnCount += cells[i].colSpan;
                        }
                    }
                }
                return columnCount;
            }

          function findSubTableIds() {
          //alert('inside findSubTableIds');
            var allElements = document.getElementsByTagName("*");
            //var ei = '';
            for (var i = 0, n = allElements.length; i < n; ++i) {
                var ei = allElements[i];
                if (ei !== null) {
                    if (ei.id) {
                        if (ei.id.startsWith("subtable_")) {
                        // console.log(el.id);
                            var arrName = ei.id.split("_");
                            var table = document.getElementById(ei.id);
                            if (table !== null) {
                                var colcount = getTableColumnCount(table);
                                if (colcount !== 0) {
                                        document.getElementById("tdColSpanId_" + arrName[1]).colSpan =colcount;
                                }
                            }
                        }
                    }
                }
            }
          }
