{
  "legislative_session": "20252026",
  "identifier": "SB990",
  "title": "Highways: exit information.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Highways",
    "exitinformation"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the Department of Transportation to adopt rules and regulations that allow the placement, near exits on freeways in rural areas, of information signs identifying specific roadside businesses. Existing law generally prohibits the placement of a sign within an urban area with a population of 5,000 or more, with certain exceptions.\n\nThis bill, until January 1, 2037, would require the department to allow the placement of information signs along southbound State Route 395 just before the State Route 178 eastbound exit and along northbound State Route 395 just before the South China Lake Boulevard northbound exit."
    }
  ],
