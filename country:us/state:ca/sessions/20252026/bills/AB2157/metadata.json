  "legislative_session": "20252026",
  "identifier": "AB2157",
  "title": "Workforce development: Displaced Oil and Gas Worker Pilot Program: extension.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DisplacedOilandGasWorkerPilotProgram",
    "Workforcedevelopment",
    "extension"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes, until July 1, 2027, the Displaced Oil and Gas Worker Pilot Program, to be administered by the Employment Development Department (department) , for the purpose of addressing employment dislocations associated with oil, gas, and related industries. That program requires the department, using funds to be appropriated by the Legislature for purposes of the program, to award grants on a competitive basis to qualified applicants, as specified, for specified eligible activities.\n\nThis bill would extend the program indefinitely by removing the July 1, 2027, repeal date."
    }
  ],
