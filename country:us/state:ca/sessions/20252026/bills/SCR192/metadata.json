  "legislative_session": "20252026",
  "identifier": "SCR192",
  "title": "Relative to open water lifeguards.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "Openwaterlifeguards"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would recognize open water lifeguards as first responders, in acknowledgment of their essential role in emergency response, public safety, and drowning prevention, as provided. The measure would urge all California public agencies employing open water lifeguards to formally recognize them as first responders in their training frameworks, emergency planning documents, and mutual-aid agreements, as provided."
    }
  ],
