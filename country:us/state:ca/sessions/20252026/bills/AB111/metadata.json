  "abstracts": [
    {
      "note": "summary",
      "abstract": "The Budget Act of 2026 would make appropriations for the support of state government for the 2026\u201327 fiscal year.\n\nThis bill would amend the Budget Act of 2026 by amending, adding, and repealing items of appropriation and making other changes.\n\nThis bill would declare that it is to take effect immediately as a Budget Bill."
    }
  ],
