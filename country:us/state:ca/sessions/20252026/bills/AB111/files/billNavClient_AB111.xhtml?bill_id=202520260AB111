               </div>
               <div>
                  <table frame="">
                     <tr>
                        <td colspan="7" valign="top" width="326">
                           <div style="">4260-001-0001—For support of State Department of Health Care Services
                              ........................
                              		
                           </div><style>span.DottedLeaders::after {content:"..................";}</style><font color="#B30000"><s><br/></s></font>
                        </td>
                        <td align="right" valign="bottom" width="80"><style>span.DottedLeaders::after {content:"..................";}</style><font color="#B30000"><s>351,964,000<br/></s></font><font color="blue" class="blue_text"><i>402,564,000</i></font></td>
