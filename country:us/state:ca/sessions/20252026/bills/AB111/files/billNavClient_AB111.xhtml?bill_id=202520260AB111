                        <td valign="top" width="24"></td>
                        <td valign="top" width="24">(9)</td>
                        <td colspan="4" style="keep-together.within-page:always;" valign="top" width="214">
                           <div style="">0150091-Civil Case Coordination
                              ........................
                              		
                           </div>
                        </td>
                        <td align="right" valign="bottom" width="74">832,000</td>
                        <td valign="bottom" width="80"></td>
                     </tr>
                     <tr>
                        <td valign="top" width="24"></td>
                        <td valign="top" width="24">(10)</td>
                        <td colspan="4" style="keep-together.within-page:always;" valign="top" width="214">
                           <div style="">0150095-Expenses on Behalf of the Trial Courts
                              ........................
                              		
                           </div>
                        </td>
                        <td align="right" valign="bottom" width="74">23,337,000</td>
                        <td valign="bottom" width="80"></td>
                     </tr>
                     <tr>
                        <td valign="top" width="24"></td>
                        <td valign="top" width="24">(11)</td>
                        <td colspan="4" style="keep-together.within-page:always;" valign="top" width="214">
                           <div style="">Reimbursements to 0150010-Support for Operation of Trial Courts
                              ........................
                              		
                           </div>
