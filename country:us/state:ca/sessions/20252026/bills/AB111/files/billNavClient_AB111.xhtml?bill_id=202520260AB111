               </div>
               <div>
                  <table frame="">
                     <tr>
                        <td colspan="7" valign="top" width="326">
                           <div style="">4265-111-0001—For local assistance, State Department of Public Health
                              ........................
                              		
                           </div><style>span.DottedLeaders::after {content:"..................";}</style><font color="#B30000"><s><br/></s></font>
                        </td>
                        <td align="right" valign="bottom" width="80"><style>span.DottedLeaders::after {content:"..................";}</style><font color="#B30000"><s>363,537,000<br/></s></font><font color="blue" class="blue_text"><i>368,742,000</i></font></td>
                     </tr>
                     <tr>
                        <td valign="top" width="24"></td>
                        <td colspan="6" valign="top" width="312">
                           <div style="">Schedule:</div>
                        </td>
                        <td valign="bottom" width="80"></td>
                     </tr>
                     <tr>
                        <td valign="top" width="24"></td>
                        <td valign="top" width="24">(1)</td>
