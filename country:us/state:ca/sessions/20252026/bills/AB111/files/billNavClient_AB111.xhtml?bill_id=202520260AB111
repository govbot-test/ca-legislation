               </div>
               <div>
                  <table frame="">
                     <tr>
                        <td colspan="7" valign="top" width="336">
                           <div style="">7350-101-3078—For local assistance, Department of Industrial Relations, payable from the Labor and Workforce Development Fund
                              ........................
                              		
                           </div><style>span.DottedLeaders::after {content:"..................";}</style><font color="#B30000"><s><br/></s></font>
                        </td>
                        <td align="right" valign="bottom" width="80"><style>span.DottedLeaders::after {content:"..................";}</style><font color="#B30000"><s>39,000,000<br/></s></font><font color="blue" class="blue_text"><i>44,000,000</i></font></td>
                     </tr>
                     <tr>
                        <td valign="top" width="24"></td>
                        <td colspan="7" valign="top" width="392">Schedule:</td>
                     </tr>
                     <tr>
                        <td valign="top" width="24"></td>
