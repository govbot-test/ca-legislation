                     <tr>
                        <td valign="top" width="24"></td>
                        <td valign="top" width="24"></td>
                        <td valign="top" width="24">(a)</td>
                        <td colspan="4" valign="top" width="264">
                           <div style="">The loan is to meet cash needs resulting from the delay in receipt of reimbursements for services provided.</div>
                        </td>
                        <td valign="bottom" width="80"></td>
                     </tr>
                     <tr>
                        <td valign="top" width="24"></td>
                        <td valign="top" width="24"></td>
                        <td valign="top" width="24">(b)</td>
                        <td colspan="4" valign="top" width="264">
                           <div style="">The loan is for a short term and shall be repaid by November 15 of the fiscal year following that in which the loan was authorized.</div>
                        </td>
                        <td valign="bottom" width="80"></td>
                     </tr>
                     <tr>
                        <td valign="top" width="24"></td>
                        <td valign="top" width="24"></td>
                        <td valign="top" width="24">(c)</td>
                        <td colspan="4" valign="top" width="264">
