{
  "legislative_session": "20252026",
  "identifier": "AB2226",
  "title": "Reusable grocery bags.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Reusablegrocerybags"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law prohibits a store, as defined, from providing a precheckout bag, as defined, to a customer unless the precheckout bag is a compostable bag that meets certain criteria or a recycled paper bag. Existing law defines a \"precheckout bag\" for this purpose to mean a bag provided to a customer before the customer reaches the point of sale, that is designed to protect a purchased item from damaging or contaminating other purchased items in a checkout bag, or to contain an unwrapped food item.\n\nThis bill would repeal those provisions."
    }
  ],
