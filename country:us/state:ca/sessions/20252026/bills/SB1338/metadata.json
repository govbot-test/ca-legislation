{
  "legislative_session": "20252026",
  "identifier": "SB1338",
  "title": "Vehicles: repossession.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Vehicles",
    "repossession"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law prohibits a person from interfering with the transport of a vehicle to a storage facility, auction, or dealer by an individual who is employed by a repossession agency or is licensed as a repossession agency once repossession is complete, as provided. Under existing law, a violation of this provision is an infraction, punishable by specified fines.\n\nThis bill would double the fines, as specified."
    }
  ],
