  "identifier": "AB2639",
  "title": "Merced County Flood Control District: assessment.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "MercedCountyFloodControlDistrict",
    "assessment"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law, the Merced County Flood Control District Act, establishes the Merced County Flood Control District to control the flood and stormwaters of the district, which consists of all the territory of the County of Merced.\n\nThis bill would require the Legislative Analyst's Office to conduct and submit to the Legislature and the Governor an assessment, on or before July 1, 2027, evaluating the efficacy of the Merced County Flood Control District, as prescribed."
    }
  ],
