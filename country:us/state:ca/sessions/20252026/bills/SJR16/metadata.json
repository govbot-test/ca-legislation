  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would urge the Congress of the United States and the Federal Motor Carrier Safety Administration to review federal commercial driver's license disqualification policies and consider reforms that allow greater flexibility for states and appropriate relief for drivers whose livelihoods are affected."
    }
  ],
