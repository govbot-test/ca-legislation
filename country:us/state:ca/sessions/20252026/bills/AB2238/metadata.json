{
  "legislative_session": "20252026",
  "identifier": "AB2238",
  "title": "Mobilehome Residency Law: civil action: physical improvements.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "MobilehomeResidencyLaw",
    "civilaction",
    "physicalimprovements"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law, the Mobilehome Residency Law, prescribes various terms and conditions of tenancies in mobilehome parks. Existing law prohibits an action based upon the management's alleged failure to maintain the physical improvement in the common facilities in good working order or condition or alleged reduction of service from being commenced by a homeowner unless the management has been given at least 30 days' prior notice of the intention to commence the action.\n\nThis bill would authorize management to move to dismiss with prejudice a claim that alleges a failure to maintain, or a reduction of service regarding, a physical improvement, as described above, if that physical improvement is not actually present within the mobilehome park, nor provided or under the control of the park owner or manager. The bill would, upon petition by the management, require a court that grants a motion to dismiss for this reason to award the management reasonable attorney's fees and impose a civil penalty and other sanctions to be paid by the attorney filing the action, as specified."
    }
  ],
  "other_titles": [
