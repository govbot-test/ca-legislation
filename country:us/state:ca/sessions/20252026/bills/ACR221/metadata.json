  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would recognize that sudden cardiac arrest is a critical issue facing student athletes and provide that the Legislature supports the important work nonprofit organizations are doing to raise awareness of sudden cardiac arrest, increase preventative screenings, and reduce the number of cases."
    }
