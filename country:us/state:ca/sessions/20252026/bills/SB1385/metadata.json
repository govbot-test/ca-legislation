  "subject": [
    "EmploymentDevelopmentDepartment"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Employment Development Department within the Labor and Workforce Development Agency and requires the department to pay unemployment compensation benefits to unemployed individuals who are eligible to receive benefits, as specified. Existing law requires the department to be administered by an executive officer known as the Director of Employment Development, and vests the department and director with specified duties, purposes, responsibilities, and jurisdiction. Existing law, as part of these administrative provisions, grants the department possession of prescribed property.\n\nThis bill would make nonsubstantive changes to that property provision."
    }
  ],
