{
  "legislative_session": "20252026",
  "identifier": "SB607",
  "title": "Golden Gate Bridge, Highway and Transportation District: contributions and loans.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "GoldenGateBridge,HighwayandTransportationDistrict",
    "contributionsandloans"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law prohibits the Golden Gate Bridge, Highway and Transportation District from issuing general obligation or revenue bonds, or any other form of long-term indebtedness, except to finance an interim system of buses and ferries or to finance capital improvements or modifications relating to seismic safety of the Golden Gate Bridge.\n\nThis bill would authorize the district to accept contributions and loans from this state and the United States for the purpose of financing capital improvements or modifications related to seismic safety on the Golden Gate Bridge, as specified."
    }
  ],
