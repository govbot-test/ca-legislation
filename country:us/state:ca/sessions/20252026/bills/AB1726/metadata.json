  "identifier": "AB1726",
  "title": "Natural disasters: catastrophe savings accounts: personal income tax.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Naturaldisasters",
    "catastrophesavingsaccounts",
