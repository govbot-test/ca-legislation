{
  "legislative_session": "20252026",
  "identifier": "SB932",
  "title": "Civil proceedings: real party in interest.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civilproceedings",
    "realpartyininterest"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires an action to be prosecuted in the name of the real party in interest, except as otherwise provided by statute.\n\nThis bill would require an assignee to identify the assignor who is the original real party in interest in the title of the case on the first document the assignee files in a proceeding."
    }
  ],
