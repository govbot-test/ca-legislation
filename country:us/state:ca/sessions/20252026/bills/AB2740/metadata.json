{
  "legislative_session": "20252026",
  "identifier": "AB2740",
  "title": "Enforcement of money judgments: exemptions.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Enforcementofmoneyjudgments",
    "exemptions"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law identifies various types of property of a judgment debtor that are exempt from the enforcement of a money judgment, including material that in good faith is about to be applied to the repair or improvement of a residence, as specified.\n\nThis bill would specify that this exemption would apply to the judgment debtor's principal place of residence or domicile."
    }
  ],
