  "legislative_session": "20252026",
  "identifier": "AB1714",
  "title": "Personal income tax: credit: first-time homebuyer program: required repairs.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Personalincometax",
    "credit",
    "first-timehomebuyerprogram",
    "requiredrepairs"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The Personal Income Tax Law allows various credits against the taxes imposed by those laws.\n\nThis bill would allow a credit against those taxes for each taxable year beginning on or after January 1, 2028, and before January 1, 2033, in an amount equal to 40% of the amount paid or incurred, not to exceed $25,000, during the taxable year for repairs that are required as a condition of closing the sale of real property to a purchaser utilizing a first-time homebuyer assistance program, as specified. The bill would prohibit a taxpayer from claiming more than one credit for a taxable year or more than one taxpayer from claiming the credit with respect to a property for a taxable year.\n\nExisting law requires any bill authorizing a new tax expenditure, as defined, to include tax credits, to contain, among other things, specific goals, purposes, and objectives that the tax credit will achieve, detailed performance indicators, and data collection requirements.\n\nThis bill would include findings and reporting requirements in compliance with this requirement.\n\nThis bill would take effect immediately as a tax levy."
    }
  ],
