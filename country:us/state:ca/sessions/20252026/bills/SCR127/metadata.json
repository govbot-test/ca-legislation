{
  "legislative_session": "20252026",
  "identifier": "SCR127",
  "title": "Relative to Multifaith Heritage Month.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "MultifaithHeritageMonth"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would designate the month of December each year as Multifaith Heritage Month, and would encourage residents of California to join in fostering a community grounded in mutual respect, understanding, and harmony among diverse faiths and cultures."
    }
  ],
