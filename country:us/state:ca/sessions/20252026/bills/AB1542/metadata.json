  "legislative_session": "20252026",
  "identifier": "AB1542",
  "title": "Sensitive personal information.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Sensitivepersonalinformation"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The California Consumer Privacy Act of 2018 (CCPA) grants a consumer various rights with respect to personal information, as defined, that is collected or sold by a business, as defined, including the right to direct a business that collects sensitive personal information, as defined, about the consumer to limit its use, as prescribed. The California Privacy Rights Act of 2020, approved by the voters as Proposition 24 at the November 3, 2020, statewide general election, amended, added to, and reenacted the CCPA.\n\nThis bill would, under the CCPA, prohibit a business, service provider, or contractor from selling or sharing sensitive personal information to a third party, as specified.\n\nThis bill would declare that its provisions further the purposes and intent of the California Privacy Rights Act of 2020."
    }
  ],
