  "legislative_session": "20252026",
  "identifier": "SB999",
  "title": "Franchise Tax Board: reporting requirements.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "FranchiseTaxBoard",
    "reportingrequirements"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the Franchise Tax Board, on or before March 1, 2022, and annually on or before March 1 thereafter, to report certain information to the Legislature regarding health coverage penalties paid by households, in addition to related information.\n\nThis bill would change the annual reporting deadline to June 1, as provided."
    }
  ],
