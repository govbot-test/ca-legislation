  ],
  "subject": [
    "Newstateformation"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would express the consent of the Legislature for specified counties to form a new state from within the current boundaries of the State of California, and would urge Congress to accept and embrace that consent."
    }
  ],
