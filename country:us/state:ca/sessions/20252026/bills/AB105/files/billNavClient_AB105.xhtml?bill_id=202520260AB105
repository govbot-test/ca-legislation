                           </div><style>span.DottedLeaders::after {content:"..................";}</style><font color="#B30000"><s><br/></s></font>
                        </td>
                        <td align="right" valign="bottom" width="74"><style>span.DottedLeaders::after {content:"..................";}</style><font color="#B30000"><s>168,853,000<br/></s></font><font color="blue" class="blue_text"><i>163,118,000</i></font></td>
