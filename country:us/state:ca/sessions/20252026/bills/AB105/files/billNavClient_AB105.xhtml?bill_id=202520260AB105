            <div id="s2240.8171169574902923">
               <div style="margin:0 0 1em 0" class="ActionLine">
                  <h3 style="font-weight:bold; display:inline;"><font color="blue" class="blue_text"><i>SEC. 224.</i></font></h3> <font color="blue" class="blue_text"><i>Item 6870-301-6095 of Section 2.00 of the Budget Act of 2025 is amended to read:</i></font>
               </div>
               <div>
                  <table frame="">
                     <tr>
                        <td colspan="7" valign="top" width="326">
                           <div style="">6870-301-6095—For capital outlay, Board of Governors of the California Community Colleges, payable from the 2024 California Community College
                              Capital Outlay Bond Fund
                              ........................
                              		
                           </div><style>span.DottedLeaders::after {content:"..................";}</style><font color="#B30000"><s><br/></s></font>
                        </td>
                        <td align="right" valign="bottom" width="80"><style>span.DottedLeaders::after {content:"..................";}</style><font color="#B30000"><s>54,703,000<br/></s></font><font color="blue" class="blue_text"><i>142,190,000</i></font></td>
                     </tr>
                     <tr>
                        <td valign="top" width="24"></td>
                        <td colspan="5" valign="top" width="238">
                           <div style="">Schedule:</div>
