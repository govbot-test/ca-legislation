{
  "legislative_session": "20252026",
  "identifier": "AB1544",
  "title": "Court proceedings: media access.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Courtproceedings",
    "mediaaccess"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The California Constitution vests the judicial power of the state in the Supreme Court, courts of appeal, and superior courts. Existing law requires the sittings of every court to be public, except as authorized.\n\nThis bill would bar a judicial officer, peace officer, or other law enforcement officer from prohibiting a member of the press or public from accessing court proceedings that are open to the public. The bill would authorize a violation of that provision to be subject to civil penalties, as specified."
    }
  ],
