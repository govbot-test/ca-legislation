  "identifier": "SCA2",
  "title": "A resolution to propose to the people of the State of California an amendment to the Constitution of the State, by amending Section 8 of Article V thereof, relating to the Governor's powers.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "constitutional amendment"
  ],
  "subject": [
    "Governor",
    "pardonsandcommutations"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The California Constitution authorizes the Governor to grant a reprieve, pardon, or commutation after sentence has been entered, except as specified.\n\nThis measure would prohibit the Governor from granting a pardon or commutation to specified relatives."
    }
  ],
