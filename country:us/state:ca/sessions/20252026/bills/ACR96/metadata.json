{
  "legislative_session": "20252026",
  "identifier": "ACR96",
  "title": "Relative to the Assembly Member Patty Berg Memorial Highway.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "AssemblyMemberPattyBergMemorialHighway"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would designate a specified portion of State Route 101 in the County of Humboldt as the Assembly Member Patty Berg Memorial Highway. The measure would request that the Department of Transportation determine the cost of appropriate signs showing this special designation and, upon receiving donations from nonstate sources sufficient to cover the cost, to erect those signs."
    }
  ],
