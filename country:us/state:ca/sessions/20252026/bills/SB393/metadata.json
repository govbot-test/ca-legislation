  "legislative_session": "20252026",
  "identifier": "SB393",
  "title": "Pupil health: school nutrition.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Pupilhealth",
    "schoolnutrition"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law finds and declares that the State of California strives to serve food of the highest quality and of greatest nutritional value possible. Existing law requires the State Department of Education to monitor schools participating in the federal National School Lunch Program or federal School Breakfast Program to ensure that the nutrition levels of meals served to schoolage children qualify those meals for reimbursement under the federal child nutrition program regulations as nutritionally adequate breakfasts and nutritionally adequate lunches, as provided.\n\nThis bill would make a nonsubstantive change to that legislative declaration."
    }
  ],
