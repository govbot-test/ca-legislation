  "subject": [
    "GamblingControlAct"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law, the Gambling Control Act, establishes the California Gambling Control Commission, which is responsible for licensing and regulating various gambling activities and establishments. Existing law requires the commission to maintain a public record of every vote at its principal office.\n\nThis bill would additionally require the commission to post a public record of every vote on the commission's internet website no later than the close of business on the 2nd business day after the meeting at which the vote was taken."
    }
  ],
  "other_titles": [
    {
      "note": "",
      "title": "Tribal gaming: compact ratification."
    }
  ],
