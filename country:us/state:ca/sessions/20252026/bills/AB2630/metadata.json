{
  "legislative_session": "20252026",
  "identifier": "AB2630",
  "title": "Water diversion and use: adoption of regulations.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Waterdiversionanduse",
    "adoptionofregulations"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law authorizes the State Water Resources Control Board to adopt regulations requiring measurement and reporting of water diversion and use by persons, including, among others, those authorized to appropriate water under a permit, a license, a registration for small domestic, small irrigation, or livestock stockpond use, or a certificate for livestock stockpond use. For the initial regulations, existing law requires that they be adopted as emergency regulations and provides that the emergency regulations remain in effect until revised by the state board. Existing law also exempts the initial regulations from the California Environmental Quality Act.\n\nThis bill would require, until January 1, 2032, that all further regulations adopted by the state board pursuant to these provisions be adopted as emergency regulations and remain in effect until revised by the state board, and would exempt them from the California Environmental Quality Act."
    }
  ],
