{
  "legislative_session": "20252026",
  "identifier": "SB1409",
  "title": "Horse racing: charity days.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Horseracing",
    "charitydays"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires each licensed racing association that conducts 14 weeks or less of racing to designate 3 racing days, and each licensed racing association that conducts more than 14 weeks of racing to designate 5 racing days during any one meeting, to be conducted as charity days for the purpose of distributing the net proceeds to beneficiaries.\n\nThis bill would instead require each licensed racing association that conducts 12 weeks or less of racing to designate 3 racing days, and each licensed racing association that conducts more than 12 weeks of racing to designate 5 racing days during any one meeting, to be conducted as charity days for the purpose of distributing the net proceeds to beneficiaries."
    }
  ],
