  "identifier": "AB1635",
  "title": "Pit dewatering: prohibition.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Pitdewatering",
    "prohibition"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The Surface Mining and Reclamation Act of 1975 prohibits a person, with exceptions, from conducting surface mining operations unless, among other things, a permit is obtained from, a specified reclamation plan is submitted to and approved by, and financial assurances for reclamation have been approved by the lead agency for the operation of the surface mining operation.\n\nThis bill would prohibit pit dewatering, as defined, in areas with subsurface river flow or groundwater levels shallower than 50 feet below ground."
    }
  ],
