{
  "legislative_session": "20252026",
  "identifier": "AB2153",
  "title": "Voter registration: residency confirmation.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Voterregistration",
    "residencyconfirmation"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires county elections officials to update a voter's registration record if change-of-address information indicates the voter has moved to a new residence address in California. Existing law requires county elections officials to change a voter's registration status to inactive if mailings have been returned as undeliverable or if other sources of information indicate that the voter has moved out of state.\n\nThis bill would repeal an obsolete version of these requirements."
    }
  ],
