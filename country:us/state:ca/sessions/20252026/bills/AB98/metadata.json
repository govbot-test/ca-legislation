  "legislative_session": "20252026",
  "identifier": "AB98",
  "title": "State property: City of Moreno Valley.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CityofMorenoValley",
    "Stateproperty"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law authorizes the Director of General Services to execute grants to real property belonging to the state in the name and upon behalf of the state, whenever the sale or exchange of real property is authorized or contemplated by law, if no other state agency is specifically authorized and directed to execute the grants.\n\nThis bill would, subject to specified requirements, require the director to quitclaim to the City of Moreno Valley, at no cost to the city, all interests of the state in 11 specified parcels of land located in the City of Moreno Valley that consist mainly of undeveloped open-space land. The bill would require the City of Moreno Valley to use the land to conduct wildfire mitigation to ensure fire protection for residents and businesses, to increase open-space and outdoor recreational opportunities, and any other similar use the City of Moreno Valley deems necessary. The bill would exempt the land from specified provisions of law governing the disposal of surplus state and local real property.\n\nThis bill would make legislative findings and declarations as to the necessity of a special statute for the City of Moreno Valley.\n\nThis bill would make legislative findings and declarations related to a gift of public funds."
    }
  ],
