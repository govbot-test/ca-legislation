  "subject": [
    "TheEveryKidCounts(EKC)CollegeSavingsProgram"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Every Kid Counts (EKC) College Savings Program, which requires the Student Aid Commission to implement and administer a grant program that supports local governments and other entities that sponsor one or more comprehensive citywide or regional children's savings account programs to help families, especially low-income families with young children, establish and maintain college savings accounts.\n\nThis bill would make nonsubstantive changes to those provisions."
    }
  ],
