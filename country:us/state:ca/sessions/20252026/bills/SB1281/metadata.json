  ],
  "subject": [
    "Publicresources",
    "certifiedcommunityconservationcorps"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law provides for certified community conservation corps, defined as a community conservation corps that was in existence on September 30, 1999, or that is formed subsequent to that date, and that is designated by a city or a city and county to perform litter abatement, recycling, and related activities, if the city or the city and county has a population, as determined by the most recent census, of more than 250,000 persons.\n\nThis bill would make nonsubstantive changes to that provision."
    }
  ],
