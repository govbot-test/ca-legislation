{
  "legislative_session": "20252026",
  "identifier": "AB1909",
  "title": "Off-highway vehicle: emergency response situation.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Off-highwayvehicle",
    "emergencyresponsesituation"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Under existing law, generally a motor vehicle may not be driven upon a highway unless it is registered. However, off-highway motor vehicles issued an identification plate or device may cross highways under specified conditions, including, among others, a peace officer in an emergency response situation.\n\nThis bill would similarly authorize first responders, as defined, to operate or drive an off-highway vehicle upon a highway to provide emergency response services or while performing official departmental duties."
    }
  ],
