  ],
  "subject": [
    "TheParoleAgentJoshuaLByrdMemorialHighway"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would designate an unspecified portion of State Highway Route 80 in the County of Solano as the Parole Agent Joshua L. Byrd Memorial Highway. The measure would request that the Department of Transportation determine the cost of appropriate signs showing this special designation and, upon receiving donations from nonstate sources sufficient to cover the cost, to erect those signs."
    }
  ],
