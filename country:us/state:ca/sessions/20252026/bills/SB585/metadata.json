  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law provides that a livestock or poultry product is misbranded in each of specified cases, including when its labeling is false or misleading in any particular.\n\nThis bill would make a nonsubstantive change to that provision."
    }
  ],
