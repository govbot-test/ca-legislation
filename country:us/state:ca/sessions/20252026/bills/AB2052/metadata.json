{
  "legislative_session": "20252026",
  "identifier": "AB2052",
  "title": "Criminal procedure: continuances.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Criminalprocedure",
    "continuances"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the requirements for a continuance to be granted in a criminal case, including a showing of good cause. Existing law defines \"good cause\" for this purpose to include, but not be limited to, cases involving specified crimes, including murder and domestic violence, and to apply when the prosecuting attorney assigned to the case has another trial, preliminary hearing, or motion to suppress in progress in that court or another court.\n\nThis bill would expand the types of cases that may support a finding of good cause to include a felony of elder or dependent adult abuse violation where the victim is a cognitively impaired adult, as specified. The bill would define \"cognitively impaired adult\" for these purposes."
    }
  ],
