  "subject": [
    "SpecialOlympicsDay"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would proclaim March 9, 2026, as Special Olympics Day in California, and congratulate Team NorCal and Team SoCal for their accomplishments thus far and wish them success in the 2026 Special Olympics USA Games."
    }
  ],
