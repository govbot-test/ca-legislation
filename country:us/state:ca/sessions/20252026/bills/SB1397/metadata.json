  "identifier": "SB1397",
  "title": "Mountain Lions: human-mountain lion conflicts program: scientific research.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "MountainLions",
