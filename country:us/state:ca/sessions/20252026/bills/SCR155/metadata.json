{
  "legislative_session": "20252026",
  "identifier": "SCR155",
  "title": "Relative to the Officer Kirk Leland Johnson Memorial Interchange.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "OfficerKirkLelandJohnsonMemorialInterchange"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would designate the interchange at State Route 52 and Interstate 805 in the County of San Diego as the Officer Kirk Leland Johnson Memorial Interchange. The measure would request that the Department of Transportation determine the cost of appropriate signs showing this special designation and, upon receiving donations from nonstate sources sufficient to cover the cost, to erect those signs."
    }
  ],
