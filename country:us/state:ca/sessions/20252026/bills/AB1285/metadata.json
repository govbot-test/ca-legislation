{
  "legislative_session": "20252026",
  "identifier": "AB1285",
  "title": "State Fire Marshal: lithium-ion battery facilities: guidance.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "StateFireMarshal",
    "guidance",
    "lithium-ionbatteryfacilities"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the State Fire Marshal to encourage the adoption of fire prevention measures by means of education, engineering, and enforcement and to prepare or cause to be prepared for dissemination information relating to the subject of fire prevention and extinguishment.\n\nThis bill would require the State Fire Marshal, in consultation with the Office of Emergency Services, to develop fire prevention, response, and recovery measures for utility grade lithium-ion battery storage facilities, as specified."
    }
  ],
