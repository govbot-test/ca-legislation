  "subject": [
    "Pupilinstruction",
    "digitalwellness"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the State Department of Education, on or before January 1, 2024, to develop a plan to expand mental health instruction in California public schools.\n\nThis bill would require the department, on or before January 1, 2028, to develop a plan to expand digital wellness instruction in California public schools, as provided."
    }
  ],
