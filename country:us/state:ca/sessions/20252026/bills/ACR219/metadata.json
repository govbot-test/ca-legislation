  "legislative_session": "20252026",
  "identifier": "ACR219",
  "title": "Relative to California OB-GYN Week.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "CaliforniaOB-GYNWeek"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would designate the week of May 24, 2026, to May 30, 2026, inclusive, as California OB-GYN Week to recognize the essential contributions of obstetricians and gynecologists (OB-GYNs) to the health care system and the critical role they play in delivering comprehensive, preventive, and primary care services, and to encourage the continued recognition and support of OB-GYNs to ensure access to high-quality, equitable health care for all Californians."
    }
  ],
