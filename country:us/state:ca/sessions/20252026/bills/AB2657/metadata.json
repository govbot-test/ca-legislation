  "subject": [
    "Prescriptions"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law, the California Uniform Controlled Substances Act, classifies controlled substances into 5 designated schedules, with the most restrictive limitations generally placed on controlled substances classified in Schedule I, and the least restrictive limitations generally placed on controlled substances classified in Schedule V. Existing law prohibits the delivery of Schedule II, III, or IV controlled substances to a pharmacy unless a receipt for the merchandise is signed by a pharmacist or authorized receiving personnel. A violation of this provision is a crime.\n\nThis bill would make nonsubstantive changes to this provision."
    }
  ],
