{
  "legislative_session": "20252026",
  "identifier": "AB1399",
  "title": "Department of Transportation: encroachment permits: broadband facilities.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DepartmentofTransportation",
    "broadbandfacilities",
    "encroachmentpermits"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Department of Transportation and vests it with full possession and control of all state highways and all property and rights in property for state highway purposes. Existing law authorizes the department to issue a written permit to place an encroachment on the state highway. Existing law requires the department to perform certain actions if the encroachment permit application is for a broadband facility.\n\nThis bill would require the department to perform additional actions for an encroachment permit application for a broadband facility, including, but not limited to, requiring the application and review process for the application to be uniform throughout the state, and would require a broadband facility encroachment permit application that is deemed complete to be deemed approved."
    }
  ],
