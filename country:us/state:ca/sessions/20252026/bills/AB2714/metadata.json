  "subject": [
    "Unemploymentcompensation"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Employment Development Department, administered by the Director of Employment Development who is vested with certain duties relating to unemployment compensation. Under existing law, employer contributions to the Unemployment Fund accrue and become payable by every employer, except as specified, for each calendar year with respect to wages paid for employment. Existing law prohibits employers from deducting the required employer contributions from the wages of their employees.\n\nThis bill would make a nonsubstantive change to that latter provision."
    }
  ],
