  "identifier": "AB2578",
  "title": "Outdoor recreation: outdoor economy: strategic initiatives: support organizations.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Outdoorrecreation",
    "outdooreconomy",
