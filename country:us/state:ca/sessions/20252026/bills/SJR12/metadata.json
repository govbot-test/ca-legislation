{
  "legislative_session": "20252026",
  "identifier": "SJR12",
  "title": "Proposed 2026\u20132031 National Outer Continental Shelf Oil and Gas Leasing Program: opposition.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [
    "Proposed2026\u20132031NationalOuterContinentalShelfOilandGasLeasingProgram",
    "opposition"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would request that the federal Bureau of Ocean Energy Management hold public hearings in California on the proposed 2026\u20132031 National Outer Continental Shelf Oil and Gas Leasing Program, prepare an environmental impact statement to accompany the program, and provide the public the opportunity to comment on a draft programmatic environmental impact statement for potential offshore oil and gas leasing in California. The measure would strongly and unequivocally oppose any new offshore drilling and declare unequivocal support for the current federal prohibition on new oil or gas drilling in federal waters offshore of the Pacific coast."
    }
  ],
