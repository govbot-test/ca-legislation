{
  "legislative_session": "20252026",
  "identifier": "AB1603",
  "title": "Perfluoroalkyl and polyfluoroalkyl substances (PFAS): Department of Pesticide Regulation.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DepartmentofPesticideRegulation",
    "Perfluoroalkylandpolyfluoroalkylsubstances(PFAS)"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law generally regulates the use of pesticides, and requires every manufacturer of, importer of, or dealer in any pesticide, except as specified, to obtain a certificate of registration from the Department of Pesticide Regulation before the pesticide is offered for sale. Existing law requires a pesticide use report to be submitted to a county agricultural commissioner or the Director of Pesticide Regulation, as provided.\n\nThis bill would require the department to indicate if a pesticide contains perfluoroalkyl and polyfluoroalkyl substances (PFAS) pesticide ingredients, as defined, in the pesticide use reporting database on its internet website, include PFAS as a category of interest for purposes of that database, and include pesticide use trends of PFAS pesticide ingredients from the pesticide database in the pesticide use annual report and other relevant pesticide use reporting documents. The bill would also require the department to publish a list of all registered pesticides that contain PFAS pesticide ingredients, as specified."
    }
  ],
  "other_titles": [
    {
      "note": "",
      "title": "Department of Pesticide Regulation: chlorpyrifos: quarterly reports."
    }
  ],
