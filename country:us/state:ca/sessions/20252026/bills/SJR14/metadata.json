    "WorldWarIINursesCongressionalGoldMedalAct"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would urge the United States Congress to act favorably in regard to legislation, Senate Bill 2195 and House of Representatives Bill 4901 to award the Congressional Gold Medal to the World War II members of the United States Army Nurse Corps and the United States Navy Nurse Corps."
    }
  ],
