{
  "legislative_session": "20252026",
  "identifier": "SCR164",
  "title": "Relative to Black Health Equity Advocacy Week.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "BlackHealthEquityAdvocacyWeek"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would recognize May 4, 2026, to May 8, 2026, inclusive, and every first full week of May thereafter, as Black Health Equity Advocacy Week and commend the California Black Health Network and other organizations throughout the state for their efforts to improve the health, well-being, and life expectancy of Black Californians."
    }
  ],
