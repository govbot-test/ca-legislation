  "legislative_session": "20252026",
  "identifier": "SCR167",
  "title": "Relative to Mother's Day.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "Mother'sDay"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would recognize May 10, 2026, as the 119th annual Mother's Day and would urge all Californians to recognize, appreciate, and be grateful for the gifts and good works of mothers on that day."
    }
  ],
