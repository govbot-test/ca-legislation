  "identifier": "SB1433",
  "title": "Maintenance of the codes.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Maintenanceofthecodes"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law directs the Legislative Counsel to advise the Legislature from time to time as to legislation necessary to maintain the codes.\n\nThis bill would make nonsubstantive changes in various provisions of the law to effectuate the recommendations made by the Legislative Counsel to the Legislature."
    }
  ],
