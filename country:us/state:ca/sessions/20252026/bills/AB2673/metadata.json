  "legislative_session": "20252026",
  "identifier": "AB2673",
  "title": "Personal Income Tax Law: Corporation Tax Law: credit: childcare.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CorporationTaxLaw",
