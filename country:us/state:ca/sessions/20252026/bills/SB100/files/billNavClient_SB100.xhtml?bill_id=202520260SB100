                     <tr>
                        <td valign="top" width="24"></td>
                        <td valign="top" width="24">(5)</td>
                        <td colspan="4" style="keep-together.within-page:always;" valign="top" width="214">
                           <div style="">Reimbursements to 5381-Preparation and Licensing of Teachers
                              ........................
                              		
                           </div>
