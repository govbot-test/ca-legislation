{
  "legislative_session": "20252026",
  "identifier": "AB2455",
  "title": "Bruce Lee Day.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "BruceLeeDay"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the Governor to proclaim certain days each year for specified reasons. Existing law also designates particular days each year as having special significance and encourages all public schools and educational institutions to observe those days and to conduct suitable commemorative exercises on those days.\n\nThis bill would require the Governor to annually proclaim May 17 as Bruce Lee Day, would designate and set apart that date each year as having special significance, and would encourage all public schools and educational institutions to observe that date by conducting exercises remembering the life of Bruce Lee and recognizing his accomplishments and the contributions he made to the state."
    }
  ],
