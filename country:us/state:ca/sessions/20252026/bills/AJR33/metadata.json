  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would urge the President and the Congress of the United States to initiate a temporary moratorium on the enforcement of copyright claims, content identification matches, or monetization actions originating from any claimants or multichannel networks based in a nation deemed to be a Priority Foreign Country by the Office of the United States Trade Representative."
    }
  ],
