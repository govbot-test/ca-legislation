  "identifier": "AJR33",
  "title": "Intellectual property enforcement: Priority Foreign Countries.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [
    "Intellectualpropertyenforcement",
