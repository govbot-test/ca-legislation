{
  "legislative_session": "20252026",
  "identifier": "AB2015",
  "title": "Department of Transportation: third-party navigation applications: study and report.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DepartmentofTransportation",
    "studyandreport",
    "third-partynavigationapplications"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Department of Transportation and vests it with full possession and control of the state highway system. \n\nThis bill would require the department, in consultation with the Transportation Agency and local authorities, to conduct a comprehensive study on the impact of third-party navigation applications on the state highway system and local street and road networks. The bill would require the study to analyze how third-party navigation applications affect congestion displacement, local infrastructure, safety metrics, and emergency response, as provided. The bill would require the department, on or before January 1, 2028, to submit the study, and a report of related policy recommendations for regulatory or legislative action to improve the alignment between third-party navigation applications and state and local traffic management goals, to the relevant fiscal and policy committees of the Legislature. The bill would repeal these provisions on January 1, 2032."
    }
  ],
