  "identifier": "SB949",
  "title": "Environmental protection: Natural Resources Agency: resource of statewide significance: Santa Cruz Mountains.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Environmentalprotection",
    "NaturalResourcesAgency",
    "SantaCruzMountains",
