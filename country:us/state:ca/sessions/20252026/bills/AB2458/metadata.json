{
  "legislative_session": "20252026",
  "identifier": "AB2458",
  "title": "Energy: appliance standards and cost-effective measures.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Energy",
    "appliancestandardsandcost-effectivemeasures"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the State Energy Resources Conservation and Development Commission (Energy Commission) to prescribe, by regulation, standards for minimum levels of operating efficiency, and authorizes the Energy Commission to prescribe other cost-effective measures, to promote the use of energy- and water-efficient appliances whose use requires a significant amount of energy or water. Existing law prohibits the sale, and the offering for sale, of new appliances unless their manufacturers certify that they comply with the standards in effect at the time the appliances are manufactured. Existing law defines \"sold or offered for sale in the state\" to mean any sale of or offer to sell an appliance for end use in the state, regardless of the seller's physical location. \n\nThis bill would expand the above-described provisions to also include the rental, importation, distribution, or lease of, or an offer for the rental, importation, distribution, or lease of, those appliances, as provided."
    }
  ],
