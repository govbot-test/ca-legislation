{
  "legislative_session": "20252026",
  "identifier": "AB1707",
  "title": "Electricians: certification application, examination, and renewal.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Electricians",
    "certificationapplication,examination,andrenewal"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Division of Labor Standards Enforcement, under the direction of the Labor Commissioner, within the Department of Industrial Relations, for the purpose of enforcing labor laws. Existing law requires the division to maintain minimum standards for the competency and training of electricians through a system of testing and certification. Existing law requires the division to issue certification cards to electricians who have been certified and paid a fee, in accordance with certain procedures.\n\n This bill would require the division to permit the application for certification and examination as an electrician to be submitted electronically and would also permit electricians to renew their certifications electronically. The bill would permit an individual who fails the electrician certification examination to reregister for certification and to retake the examination again immediately at the next available appointment with the division."
    }
  ],
