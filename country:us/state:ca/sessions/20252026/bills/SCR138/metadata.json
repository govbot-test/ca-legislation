  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would recognize the week of April 12, 2026, to April 18, 2026, inclusive, as Architecture Week in California and commend the architectural professionals whose work shapes the spaces that define our daily lives."
    }
