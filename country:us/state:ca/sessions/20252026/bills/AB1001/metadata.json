  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law authorizes an implementing agency to provide advance payment of up to 25% of grant funds awarded to public agencies, nonprofit organizations, public utilities, mobilehome parks, mutual water companies, farmers and ranchers, federally recognized California Native American tribes, nonfederally recognized Native American tribes on the contact list maintained by the Native American Heritage Commission for specified purposes, administrators, and groundwater sustainability agencies that have demonstrated cashflow problems according to the satisfaction of the implementing agency.\n\nThis bill would make a nonsubstantive change to that authorization."
    }
  ],
