{
  "legislative_session": "20252026",
  "identifier": "ACR55",
  "title": "ARC v. Department of Developmental Services: 40th anniversary.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "40thanniversary",
    "ARCvDepartmentofDevelopmentalServices"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would recognize the month of March 2025 as the 40th anniversary of the California Supreme Court decision in ARC v. Department of Developmental Services and celebrate the Legislature's 1969 passage of the Lanterman Developmental Disabilities Services Act."
    }
  ],
