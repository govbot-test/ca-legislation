{
  "legislative_session": "20252026",
  "identifier": "SB1080",
  "title": "County clerks: certification of records: signature.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Countyclerks",
    "certificationofrecords",
    "signature"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the county clerk to act as the clerk of the board of supervisors in the county and to perform specified duties, including, among other things, to take charge of, safely keep, or dispose of pursuant to law all books, papers, and records that are filed or deposited in their office pursuant to law. Existing law requires the county clerk to keep an official seal of their office for use when performing official duties.\n\nThis bill would authorize the county clerk to use a printed, stamped, photographically reproduced facsimile, electronic, or otherwise digitally created signature in certifying to a record in the county clerk's office, provided that the certification includes the official seal of the county clerk's office affixed thereto. The bill would make nonsubstantive changes, including eliminating gendered pronouns."
    }
  ],
