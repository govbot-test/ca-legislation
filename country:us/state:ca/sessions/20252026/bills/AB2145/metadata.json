  "legislative_session": "20252026",
  "identifier": "AB2145",
  "title": "Housing finance: barriers to downsizing: study.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Housingfinance",
    "barrierstodownsizing",
    "study"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Department of Housing and Community Development and authorizes the department to study the operation and enforcement of specified laws related to housing finance, taxes, redevelopment programs, and public housing projects, as related to housing and community development.\n\nThis bill would require the department, upon appropriation by the Legislature, to conduct a study to assess the need and desire among seniors 60 years of age and older to downsize their homes, as specified. The bill would require the department to submit a report on the study to the Legislature within one year of an appropriation made for this purpose. The bill would repeal its provisions on January 1, 2032."
    }
  ],
