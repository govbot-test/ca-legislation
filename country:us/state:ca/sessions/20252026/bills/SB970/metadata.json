{
  "legislative_session": "20252026",
  "identifier": "SB970",
  "title": "Military or overseas voters.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Militaryoroverseasvoters"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law regulates the voting procedures for military or overseas voters to register to vote, to apply for voting ballots, and to vote. Existing law requires, among other things, unvoted voting materials to be electronically transmitted to a military or overseas voter.\n\nThis bill would require the Secretary of State to promulgate regulations to facilitate the secure return of ballots from military or overseas voters delivered through secure methods."
    }
  ],
