{
  "legislative_session": "20252026",
  "identifier": "AB999",
  "title": "Skydiving or sport parachuting operations.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Skydivingorsportparachutingoperations"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires owners and operators of a skydiving or sport parachuting operation to have a duty to ensure that the parachutist in command of a tandem jump and the parachute rigger responsible for packing the parachute are in compliance with all federal laws relating to parachute safety and certification, to the extent allowed by federal law.\n\nThis bill would make a nonsubstantive change to that provision."
    }
  ],
