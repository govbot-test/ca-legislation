  "legislative_session": "20252026",
  "identifier": "AB1718",
  "title": "Teacher credentialing: professional preparation.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Teachercredentialing",
    "professionalpreparation"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the Commission on Teacher Credentialing to establish standards for the issuance and renewal of credentials. Existing law requires, as a minimum requirement for a preliminary multiple subject, single subject, or education specialist teaching credential, the satisfactory completion of a program of professional preparation, as specified. Existing law requires professional preparation to be made available in the upper division course offerings at all California public institutions of higher learning, except as provided.\n\nThis bill would make nonsubstantive changes to the latter provision."
    }
  ],
