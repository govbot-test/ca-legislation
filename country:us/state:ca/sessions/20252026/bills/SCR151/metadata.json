  "legislative_session": "20252026",
  "identifier": "SCR151",
  "title": "Relative to Anterior Cruciate Ligament (ACL) Injury Awareness Month.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "AnteriorCruciateLigamentInjuryAwarenessMonth"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would proclaim the month of May 2026 as Anterior Cruciate Ligament (ACL) Injury Awareness Month and encourage schools, youth sports organizations, athletic programs, and health professionals to promote evidence-based injury prevention education and training."
    }
  ],
