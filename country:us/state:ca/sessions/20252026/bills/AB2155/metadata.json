{
  "legislative_session": "20252026",
  "identifier": "AB2155",
  "title": "Arbitration: validity of agreements to arbitrate.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Arbitration",
    "validityofagreementstoarbitrate"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law provides that written agreements to submit controversies to arbitration are valid and enforceable. Existing federal law, the Federal Arbitration Act, also deems arbitration agreements valid, irrevocable, and enforceable, except for certain specified types of agreements, such as agreements to arbitrate claims of sexual harassment.\n\nThis bill would make agreements to submit to arbitration unenforceable where the agreement would not be enforceable under the Federal Arbitration Act."
    }
  ],
