  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law imposes various reporting requirements on state agencies.\n\nThis bill would require state agencies that impose monetary charges, as defined, to report the revenue generated from those charges on their internet website on or before January 1, 2028, and annually thereafter. The bill would require the reports to be made available for download in machine-readable format, as specified."
    }
  ],
