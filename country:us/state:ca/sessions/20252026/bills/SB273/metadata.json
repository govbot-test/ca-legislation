    "Surplusland"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law declares that surplus government land should be made available for affordable housing, including near transit stations, and for parks and recreation or open-space purposes.\n\nThis bill would make a nonsubstantive change to this provision."
    }
  ],
