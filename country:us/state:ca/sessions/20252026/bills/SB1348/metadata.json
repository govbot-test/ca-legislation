    "Lifeanddisabilityinsurancecontracts"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law generally regulates classes of insurance, including life and disability insurance. Existing law grants a person an insurable interest in the life and health of, among others, themselves or a person upon whom they depend for education or support.\n\nThis bill would make technical, nonsubstantive changes to that provision."
    }
  ],
