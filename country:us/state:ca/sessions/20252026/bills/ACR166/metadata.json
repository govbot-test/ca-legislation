{
  "legislative_session": "20252026",
  "identifier": "ACR166",
  "title": "State of Zacatecas: sister-state relationship.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "StateofZacatecas",
    "sister-staterelationship"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would express the intent of the Legislature to formalize a sister-state relationship between the State of Zacatecas in Mexico and the State of California, in recognition of their shared heritage, economic opportunities, and mutual commitment to prosperity, dignity, and understanding."
    }
  ],
