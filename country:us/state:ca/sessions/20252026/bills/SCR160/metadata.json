  ],
  "subject": [
    "Medicallysupportivefood"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would call on Medi-Cal managed care plans operating across the state of California to sustain and expand medically supportive food and nutrition services offerings to Medi-Cal patients through federal In Lieu of Services (ILOS) authority until these services can become permanent Medi-Cal benefits."
    }
  ],
