  "legislative_session": "20252026",
  "identifier": "SB1178",
  "title": "California State Library: study: state wasp.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "CaliforniaStateLibrary",
    "statewasp",
    "study"
