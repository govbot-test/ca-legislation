  "title": "Relative to California Fairgrounds Appreciation Month.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "CaliforniaFairgroundsAppreciationMonth"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would designate the month of May 2026 as California Fairgrounds Appreciation Month in appreciation for the services provided to California by the fairgrounds and fairs in the state."
    }
  ],
