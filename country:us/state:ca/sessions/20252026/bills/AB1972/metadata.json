{
  "legislative_session": "20252026",
  "identifier": "AB1972",
  "title": "Water right permits and licenses: annual fee: exemption.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Waterrightpermitsandlicenses",
    "annualfee",
    "exemption"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires each person or entity who holds a permit or license to appropriate water, leases water pursuant to specified provisions of law, or files a specified application, registration, or petition to pay a fee according to a fee schedule established by the State Water Resources Control Board.\n\nThis bill would require the board to exempt a person who holds a water right permit or license from paying the annual fee pursuant to a specified regulation for a pond with 20 acre-feet or less of water."
    }
  ],
  "other_titles": [
    {
      "note": "",
      "title": "Water right applicant: annual fee: exemption."
    }
  ],
