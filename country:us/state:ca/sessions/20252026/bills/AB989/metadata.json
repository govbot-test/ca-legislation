  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law includes the 4th Friday in September, known as \"Native American Day,\" as a state holiday.\n\nThis bill would provide that the 4th Friday in September, known as \"Native American Day,\" is a paid holiday for state employees, as specified."
    }
  ],
