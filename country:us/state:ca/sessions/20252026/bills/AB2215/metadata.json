{
  "legislative_session": "20252026",
  "identifier": "AB2215",
  "title": "Water rights: permits: State Water Project.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "StateWaterProject",
    "Waterrights",
    "permits"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "The Department of Water Resources operates the State Water Resources Development System, commonly referred to as the State Water Project.\n\nExisting law requires that construction work for a project that will put appropriated water to beneficial use be commenced, prosecuted with due diligence, and completed within the time period specified in the water right permit. Existing law authorizes the State Water Resources Control Board to extend the deadline specified in the permit to commence or complete construction work and to put appropriated water to beneficial use for good cause shown.\n\nThis bill would require that the time periods for the application of water to beneficial use and for the completion of construction work for specific water right permits held by the Department of Water Resources for the operation of the State Water Project be December 31, 2046."
    }
  ],
  "other_titles": [
    {
      "note": "",
      "title": "Urban water management planning."
    }
  ],
