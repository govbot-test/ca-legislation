  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law generally prohibits the sale, installation, or replacement of vehicle parts for use, or intended use, on a vehicle that is not in conformity with the Vehicle Code.\n\nThis bill would make a technical, nonsubstantive change to this provision."
    }
