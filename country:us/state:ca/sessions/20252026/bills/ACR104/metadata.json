  "subject": [
    "OutdoorWorkerAppreciationWeek"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would recognize July 14, 2025, to July 20, 2025, inclusive, as Outdoor Worker Appreciation Week. The measure would encourage local jurisdictions to recognize the week and Californians to improve the conditions of outdoor workers."
    }
  ],
