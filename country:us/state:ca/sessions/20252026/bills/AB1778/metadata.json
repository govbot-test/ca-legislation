{
  "legislative_session": "20252026",
  "identifier": "AB1778",
  "title": "Controlled substances: testosterone.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Controlledsubstances",
    "testosterone"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law, the California Uniform Controlled Substances Act, classifies controlled substances into 5 designated schedules, with the most restrictive limitations generally placed on controlled substances classified in Schedule I, and the least restrictive limitations generally placed on controlled substances classified in Schedule V. Existing federal law also regulates controlled substances by schedule. Under existing state and federal law, testosterone is classified as a Schedule III controlled substance.\n\nThis bill would, if testosterone or dihydrotestosterone is excluded from Schedule III of the federal Controlled Substances Act and reclassified to a less restrictive schedule or exempted from the act, deem it to be rescheduled or exempted, respectively, under this division."
    }
  ],
