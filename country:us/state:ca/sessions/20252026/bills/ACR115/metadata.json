{
  "legislative_session": "20252026",
  "identifier": "ACR115",
  "title": "Relative to National Blood Donor Month.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "NationalBloodDonorMonth"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would recognize January as National Blood Donor Month and urge all citizens to celebrate the cause of blood donation and recognize volunteer blood donors for their generous gifts, urge all eligible blood donors to donate regularly, and encourage businesses and organizations throughout the state to sponsor community-based blood drives with their local blood centers and provide citizens of our State with the opportunity to give."
    }
  ],
