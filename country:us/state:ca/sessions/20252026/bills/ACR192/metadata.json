  "legislative_session": "20252026",
  "identifier": "ACR192",
  "title": "Relative to the Little Saigon DMV.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "LittleSaigonDMV"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would designate the Department of Motor Vehicles (DMV) field office located at 13700 Hoover Street in the City of Westminster as the Little Saigon DMV. The measure would request the Department of General Services to determine the cost of erecting appropriate signage commemorating this special designation and, upon receiving donations from nonstate sources covering that cost, to erect that signage."
    }
  ],
