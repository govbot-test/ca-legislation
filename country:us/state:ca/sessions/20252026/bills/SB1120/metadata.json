  "identifier": "SB1120",
  "title": "Personal Income Tax Law: Corporation Tax Law: credits: CalCompetes.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill",
    "appropriation"
  ],
  "subject": [
    "CalCompetes",
    "CorporationTaxLaw",
