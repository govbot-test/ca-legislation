{
  "legislative_session": "20252026",
  "identifier": "AJR32",
  "title": "Relative to the 9/11 Remembrance Flag.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [
    "9/11RemembranceFlag"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would encourage the chief administrator of each public building or facility owned by the state, a county, or a municipality to display the 9/11 Remembrance Flag on September 11 of each year and to prescribe procedures necessary for its display. The measure would declare that any public official or chief administrator of a public building or facility may accept a donation of one or more 9/11 Remembrance Flags for the purpose of display at a public building or facility owned by the state, a county, or a municipality."
    }
  ],
