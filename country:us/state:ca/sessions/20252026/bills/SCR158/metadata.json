  "identifier": "SCR158",
  "title": "Relative to Arts, Culture, and Creativity Month and the 50th Anniversary of the California Arts Council.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "Arts,Culture,andCreativityMonthandthe50thAnniversaryoftheCaliforniaArtsCouncil"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would encourage all Californians to support the arts and would recognize April 2026 as a significant time to recognize, appreciate, and celebrate the arts, culture, and creativity of all Californians. This measure would also recognize the 50th anniversary of the California Arts Council, which supports local arts infrastructure and programming statewide through grants, programs, and services."
    }
  ],
