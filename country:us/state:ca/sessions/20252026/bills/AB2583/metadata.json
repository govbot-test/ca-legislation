{
  "legislative_session": "20252026",
  "identifier": "AB2583",
  "title": "Office of Small Business Advocate: artificial intelligence.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "OfficeofSmallBusinessAdvocate",
    "artificialintelligence"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Office of Small Business Advocate within the Governor's Office of Business and Economic Development and prescribes the duties and functions of the Small Business Advocate. Existing law requires the advocate to, among other duties, serve as the principal advocate in the state on behalf of small businesses and to represent the views and interests of small businesses before other state agencies policies and activities of which may affect small businesses.\n\nThis bill would enact the AI for Main Street Act, which would require the Small Business Advocate to provide assistance to small businesses in evaluating artificial intelligence concerning operations, including by providing information, guidance, and training, developing training materials, and conducting outreach, as specified."
    }
  ],
