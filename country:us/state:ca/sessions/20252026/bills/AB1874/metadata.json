{
  "legislative_session": "20252026",
  "identifier": "AB1874",
  "title": "Vehicles: driver's license suspension and revocation.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Vehicles",
    "driver'slicensesuspensionandrevocation"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the Department of Motor Vehicles to immediately revoke the driving privilege of a person upon receipt of a duly certified abstract of the record of a court showing that the person has been convicted of, among other things, certain types of manslaughter. Existing law prohibits the department from reinstating that driving privilege until 3 years after the date of revocation.\n\nThis bill would additionally prohibit the department from reinstating the driving privilege of a person convicted of those specified crimes and sentenced to incarceration in the state prison or county jail until 3 years after the date of release."
    }
  ],
