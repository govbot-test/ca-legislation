  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes a system of elementary and secondary education in this state. Under this system, public and private elementary and secondary schools throughout the state provide instruction in kindergarten and grades 1 to 12, inclusive.\n\nThis bill would state the intent of the Legislature to enact subsequent legislation that would improve educational outcomes for pupils in kindergarten and grades 1 to 12, inclusive."
    }
  ],
