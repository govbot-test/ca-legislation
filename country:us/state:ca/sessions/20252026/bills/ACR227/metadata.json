  "subject": [
    "BlackWomen'sEqualPayDay"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would proclaim July 21, 2026, as Black Women's Equal Pay Day in recognition of the need to eliminate the gender gap in earnings by African American women and to promote policies to ensure equal pay for all."
    }
  ],
