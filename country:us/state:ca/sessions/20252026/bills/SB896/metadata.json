  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law provides for various memorials and monuments on the grounds of the State Capitol. Existing law requires the Department of General Services to maintain state buildings and grounds.\n\nThis bill would authorize a nonprofit organization representing Sons of the American Revolution, in consultation with the Department of General Services, to plan, construct, and maintain a monument to the 250th Anniversary of the United States on the grounds of the State Capitol. The bill would require the nonprofit organization to submit a plan for the monument to the Joint Rules Committee for its review and approval. The bill would require the monument to be funded exclusively from private sources."
    }
  ],
