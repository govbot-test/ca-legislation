{
  "legislative_session": "20252026",
  "identifier": "ACR97",
  "title": "Relative to the Charlie Barra Memorial Bridge.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "CharlieBarraMemorialBridge"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would designate the Russian River Bridge and Overhead on State Route 20, in the County of Mendocino, as the Charlie Barra Memorial Bridge. The measure would also request the Department of Transportation to determine the cost of appropriate signs showing this special designation and, upon receiving donations from nonstate sources to cover that cost, to erect those signs."
    }
  ],
