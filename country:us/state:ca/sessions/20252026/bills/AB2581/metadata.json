  "legislative_session": "20252026",
  "identifier": "AB2581",
  "title": "Housing: affordable housing tenants: home ownership.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Housing",
    "affordablehousingtenants",
    "homeownership"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law prescribes the general responsibilities and roles of the Department of Housing and Community Development and the California Housing Finance Agency in carrying out state housing policies and programs. Existing law establishes various programs to promote development of affordable housing for tenants and homeowners, including the Multifamily Housing Program, low-income housing tax credits, and the Joe Serna, Jr. Farmworker Housing Grant Program.\n\nThis bill would, by January 1, 2028, require the department and the agency to develop and implement strategies, as specified, to promote the movement of tenants of deed-restricted affordable housing into home ownership through existing home ownership programs implemented by the department or the agency."
    }
  ],
