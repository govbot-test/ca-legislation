  "identifier": "SCR157",
  "title": "Relative to School Bus Drivers' Day.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "SchoolBusDrivers'Day"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would designate April 28, 2026, as School Bus Drivers' Day in California, in order to draw special public attention to school bus drivers for their continued and excellent services to pupils in California."
    }
  ],
