{
  "legislative_session": "20252026",
  "identifier": "AB2529",
  "title": "Civil claims: public entities and employees: declaration.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Civilclaims",
    "declaration",
    "publicentitiesandemployees"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law, the Government Claims Act, governs the tort liability and immunity of, and claims and actions against, public entities, officers, and employees.\n\nExisting law requires that a claim against a public entity or public employee be signed by the claimant or by some person on the claimant's behalf.\n\nThis bill would require a claim against a public entity or public employee to include a declaration that, upon information and belief, the contents of the claim are true and correct.\n\nBy expanding the definition of a crime, this bill would impose a state-mandated local program.\n\nThe California Constitution requires the state to reimburse local agencies and school districts for certain costs mandated by the state. Statutory provisions establish procedures for making that reimbursement.\n\nThis bill would provide that no reimbursement is required by this act for a specified reason."
    }
  ],
