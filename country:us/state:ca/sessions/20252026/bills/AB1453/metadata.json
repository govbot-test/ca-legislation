  "legislative_session": "20252026",
  "identifier": "AB1453",
  "title": "Public postsecondary education: student health: contraception and emergency contraception information.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Publicpostsecondaryeducation",
    "contraceptionandemergencycontraceptioninformation",
    "studenthealth"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the University of California, under the administration of the Regents of the University of California, and the California State University, under the administration of the Trustees of the California State University, as 2 of the segments of public postsecondary education in this state.\n\nExisting law requires, on and after January 1, 2023, each student health center on a California State University or University of California campus to offer abortion by medication techniques, as specified.\n\nThis bill would require a California State University campus, and would request a University of California campus, to provide adoption information to students in each location on campus where contraception and emergency contraception information is available, including when birth control and levonorgestrel are provided to students through the campus's student health center or pharmacy, as specified."
    }
  ],
