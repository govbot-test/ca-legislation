{
  "legislative_session": "20252026",
  "identifier": "AB1597",
  "title": "Notary public: service fees.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Notarypublic",
    "servicefees"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law authorizes the Secretary of State to appoint and commission notaries public in the number that the secretary deems necessary for the public convenience. Existing law prohibits fees charged by a notary public for certain services, including taking an acknowledgment or proof of a deed, from exceeding specified amounts.\n\nThis bill would increase those amounts, as specified, and make findings and declarations related to these provisions."
    }
  ],
