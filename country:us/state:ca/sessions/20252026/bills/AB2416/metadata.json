  "identifier": "AB2416",
  "title": "Privacy: use of a person's name, voice, signature, photograph, or likeness.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Privacy",
    "useofaperson'sname,voice,signature,photograph,orlikeness"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law makes any person who knowingly uses another's name, voice, signature, photograph, or likeness in products, merchandise, or goods, or for purposes of advertising or selling, or soliciting purchases of, products, merchandise, goods, or services, without that person's prior consent liable for damages, as specified. \n\nThis bill would make a nonsubstantive change to those provisions."
    }
  ],
