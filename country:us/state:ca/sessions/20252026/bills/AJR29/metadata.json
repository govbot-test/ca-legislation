{
  "legislative_session": "20252026",
  "identifier": "AJR29",
  "title": "Relative to voting by mail.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [
    "Votingbymail"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would declare the Legislature's opposition to any federal executive action that restricts, burdens, or interferes with California's vote by mail system and would call upon the United States Congress to reject any federal legislation that would restrict or eliminate vote by mail options and to protect the constitutional authority of states to administer their own elections."
    }
  ],
