{
  "legislative_session": "20252026",
  "identifier": "AB2156",
  "title": "Holidays: Farmworkers Day.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "FarmworkersDay",
    "Holidays"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law designates specific days as holidays in this state, including Cesar Chavez Day on March 31, and requires the Governor to annually proclaim March 31 as Cesar Chavez Day.\n\nThis bill would instead designate March 31 as Farmworkers Day and would require the Governor to annually proclaim March 31 as Farmworkers Day.\n\nThis bill would declare that it is to take effect immediately as an urgency statute."
    }
  ],
