{
  "legislative_session": "20252026",
  "identifier": "AB1808",
  "title": "Western Joshua Tree Conservation Act: industrial projects and commercial projects: single-family residences: public works projects.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "WesternJoshuaTreeConservationAct",
    "industrialprojectsandcommercialprojects",
