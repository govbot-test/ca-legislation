  "identifier": "SB1096",
  "title": "Personal income tax: senior tax credit: dependents: qualifying child.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Personalincometax",
    "dependents",
    "qualifyingchild",
