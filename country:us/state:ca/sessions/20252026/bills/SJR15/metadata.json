{
  "legislative_session": "20252026",
  "identifier": "SJR15",
  "title": "The federal Unemployment Trust Fund: debt.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [
    "ThefederalUnemploymentTrustFund",
    "debt"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would urge the United States Congress to enact federal legislation that would ensure that federal unemployment taxes on businesses are not increased due to any debt to the federal Unemployment Trust Fund that was a direct result of a state's decisions resulting in increased filings, including shutdowns, extensions of shutdowns, or lapses in fraud prevention programs."
    }
  ],
