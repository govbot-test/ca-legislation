{
  "legislative_session": "20252026",
  "identifier": "AB2272",
  "title": "State contracting: subcontractors: prompt payment.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Statecontracting",
    "promptpayment",
    "subcontractors"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law, the California Prompt Payment Act, requires a state agency that acquires property or services pursuant to a contract with a business to make payment to the person or business on the date required by the contract and as specified, or be subject to a late payment\n\n penalty. Existing law requires state agencies to encourage claimants to promptly pay their subcontractors and suppliers, especially those that are small businesses.\n\nThis bill would authorize a subcontractor or supplier performing work under a state contract to request payment status information from the awarding state agency regarding invoices submitted by the prime contractor, and would require a prime contractor to provide confirmation to the awarding agency, upon the agency's request, regarding payments made to subcontractors."
    }
  ],
