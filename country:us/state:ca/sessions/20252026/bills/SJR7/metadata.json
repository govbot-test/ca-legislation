{
  "legislative_session": "20252026",
  "identifier": "SJR7",
  "title": "Relative to tariffs.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [
    "Tariffs"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would urge President Donald J. Trump to avoid raising the cost of living for American consumers by rescinding the tariffs that he has imposed since taking office in January 2025 and refunding the American people for the costs passed on to them by his tariffs. The measure would also urge the United States Congress to enact a joint resolution to rescind President Trump's tariffs and to oppose all future unilateral and arbitrary tariff increases imposed by President Trump."
    }
  ],
