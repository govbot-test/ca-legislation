  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would recognize March 21, 2026, as the beginning of the International Day of Nowroz and extend best wishes for a peaceful and prosperous Nowroz to all Californians."
    }
  ],
