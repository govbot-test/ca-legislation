  "identifier": "AB1352",
  "title": "Community air protection programs: financial support.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill",
    "appropriation"
  ],
  "subject": [
    "Communityairprotectionprograms",
