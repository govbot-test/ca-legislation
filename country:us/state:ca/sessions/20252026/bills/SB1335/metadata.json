{
  "legislative_session": "20252026",
  "identifier": "SB1335",
  "title": "Tenancy: disposition of personal property abandoned in common areas.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Tenancy",
    "dispositionofpersonalpropertyabandonedincommonareas"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law provides optional procedures for a landlord to dispose of personal property that remains on the premises, including common areas, after a tenancy has terminated and the premises has been vacated by the tenant.\n\nThis bill would establish similar optional disposition of personal property that remains in a common area during a tenancy. The bill would require the landlord to give written notice to the tenant or any other person the landlord reasonably believes is the owner of the personal property, as provided. The bill would require the property to either be left in the common area or stored by the landlord in a place of safekeeping until the landlord releases the property, disposes of the property, or retains the property for the landlord's own use. The bill would prohibit the landlord from requiring the tenant to pay the cost of storage if the tenant reclaims the property within 15 days of having received the notice or 18 days after the notice was mailed, as provided."
    }
  ],
