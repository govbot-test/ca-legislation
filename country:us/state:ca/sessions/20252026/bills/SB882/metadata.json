{
  "legislative_session": "20252026",
  "identifier": "SB882",
  "title": "Remote court appearances.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Remotecourtappearances"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law authorizes, until January 1, 2027, a party to appear remotely and a court to conduct conferences, hearings, proceedings, and trials in civil cases, in whole or in part, through the use of remote technology.\n\nThis bill would extend the operation of these provisions to January 31, 2029. The bill would additionally authorize any non-party witness to appear remotely pursuant to these provisions."
    }
  ],
