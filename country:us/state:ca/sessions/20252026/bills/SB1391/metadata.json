  "legislative_session": "20252026",
  "identifier": "SB1391",
  "title": "Department of Consumer Affairs: retired category licenses.",
  "from_organization": "~{\"classification\": \"upper\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "DepartmentofConsumerAffairs",
    "retiredcategorylicenses"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law provides for the licensure and regulation of various professions and vocations by boards within the Department of Consumer Affairs. Existing law authorizes any of the boards within the department, except as specified, to establish by regulation a system for a retired category of license for persons who are not actively engaged in the practice of their profession or vocation. \n\nThis bill would additionally require a board that offers a retired category of licensure to disclose that information on its internet website."
    }
  ],
