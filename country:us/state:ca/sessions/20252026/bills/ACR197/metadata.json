{
  "legislative_session": "20252026",
  "identifier": "ACR197",
  "title": "Relative to Italian American Heritage Month.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "concurrent resolution"
  ],
  "subject": [
    "ItalianAmericanHeritageMonth"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would proclaim the month of October 2026 as Italian American Heritage Month, and, among other things, encourage all citizens, schools, public institutions, and community organizations in California to observe Italian American Heritage Month with appropriate ceremonies, activities, and educational programs, as specified."
    }
  ],
