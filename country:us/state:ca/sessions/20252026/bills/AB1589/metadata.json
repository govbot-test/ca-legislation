{
  "legislative_session": "20252026",
  "identifier": "AB1589",
  "title": "Firearms: silencers.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Firearms",
    "silencers"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law makes it a felony for any person, firm, or corporation to possess a silencer within this state. Existing law exempts specified actions from those provisions, including the possession of silencers by specified peace officers employed by specified law enforcement agencies or by military or naval forces, when on duty and when the use of silencers is authorized by the agency and is within the course and scope of their duties.\n\nThis bill would further exempt from the prohibition on possessing silencers specified level I reserve peace officers."
    }
  ],
