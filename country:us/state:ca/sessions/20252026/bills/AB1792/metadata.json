{
  "legislative_session": "20252026",
  "identifier": "AB1792",
  "title": "Pupil instruction: health framework: sexual health.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Pupilinstruction",
    "healthframework",
    "sexualhealth"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Instructional Quality Commission and requires the commission to, among other things, recommend curriculum frameworks to the State Board of Education.\n\nThis bill would require the commission, during the next revision of the publication \"Health Framework for California Public Schools,\" to consider including, and recommending for adoption by the state board, specific content related to sexual health instruction to educate pupils about dating abuse and digital violence, as described."
    }
  ],
