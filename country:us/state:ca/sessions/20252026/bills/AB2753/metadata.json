{
  "legislative_session": "20252026",
  "identifier": "AB2753",
  "title": "Elective office: sex offenders.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Electiveoffice",
    "sexoffenders"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law prescribes various eligibility and procedural requirements for a person to become a candidate for elective office. A person may not be a candidate for, or elected to, any state or local elective office if the person has been convicted of a felony involving bribery, embezzlement of public money, extortion or theft of public money, perjury, or conspiracy to commit any of those crimes.\n\nThis bill would additionally prohibit a person from being a candidate for, or elected to, any state or local elective office if the person has ever been required to register as a sex offender."
    }
  ],
