  "legislative_session": "20252026",
  "identifier": "AB2337",
  "title": "Peace officers: theft.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Peaceofficers",
    "theft"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law establishes the Commission on Peace Officer Standards and Training (POST) to set minimum standards for the recruitment and training of peace officers and to develop training courses and curriculum. Existing law authorizes POST to suspend or revoke the certification of a peace officer if the peace officer has engaged in any serious misconduct, as specified. Existing law requires POST to adopt by regulation a definition of \"serious misconduct\" that serves as the criteria to be considered for ineligibility for, or revocation of, certification, as provided.\n\nThis bill would additionally authorize POST to suspend or revoke the certification of a peace officer who commits specified theft under color of authority, where the peace officer acted with specific intent to permanently deprive the owner of the property."
    }
  ],
