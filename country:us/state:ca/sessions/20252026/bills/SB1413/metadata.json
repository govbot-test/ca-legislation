    "zero-emissionvehicles"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law requires the Department of General Services, beginning no later than the 2024\u201325 fiscal year, to ensure at least 50% of the light-duty vehicles purchased for the state vehicle fleet each fiscal year are zero-emission vehicles, except as provided.\n\nThis bill would make nonsubstantive changes to that requirement."
    }
  ],
