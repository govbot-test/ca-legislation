{
  "legislative_session": "20252026",
  "identifier": "AJR10",
  "title": "United States Forest Service: federal funding.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "joint resolution"
  ],
  "subject": [
    "UnitedStatesForestService",
    "federalfunding"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "This measure would call on the President of the United States to honor his promise to save American lives and communities through forest management and wildfire risk reduction projects, would request that he veto any legislation that defunds the United States Forest Service and work with Congress to protect and improve these programs, and would call for related congressional action."
    }
  ],
