{
  "legislative_session": "20252026",
  "identifier": "AB1804",
  "title": "State parks: parks passes: libraries.",
  "from_organization": "~{\"classification\": \"lower\"}",
  "classification": [
    "bill"
  ],
  "subject": [
    "Stateparks",
    "libraries",
    "parkspasses"
  ],
  "abstracts": [
    {
      "note": "summary",
      "abstract": "Existing law authorizes the Department of Parks and Recreation to collect fees, rents, and other returns for the use of any state park system area, as provided. Existing law authorizes the department to establish the California State Park Adventure Pass to be available, upon application to the department, to any child in grade 4, or grade 4 equivalent, who is a California resident and enrolled in a California public school. Existing law authorizes the department to waive the day use entrance fees to an eligible unit of the state park system for any child who holds a valid pass, as provided.\n\nThe bill would declare, among other things, that it is the policy of the state to ensure equitable and inclusive access to the state park system by empowering the department to administer programs that broaden public access to the state parks. The bill would authorize the department to work with the California State Library and individual library systems to provide park passes."
    }
  ],
